@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center align-items-center min-vh-75 py-5 fade-in-up">
    <div class="col-md-6 col-lg-5">
        <div class="glass-card shadow-lg p-5 border-0">
            <div class="text-center mb-4">
                <span class="fs-1">✨</span>
                <h2 class="fw-bold mt-2" style="background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Chào mừng trở lại</h2>
                <p class="text-muted">Đăng nhập bằng tài khoản cục bộ của bạn</p>
            </div>
            
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label text-muted">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label text-muted">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-muted">
                            Ghi nhớ tôi
                        </label>
                    </div>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg rounded-pill py-2">Đăng nhập ngay</button>
                </div>
            </form>

            @{
                if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <div class="text-center mt-4 mb-3">
                        <span class="text-muted small px-3 bg-white" style="position: relative; z-index: 1;">Hoặc đăng nhập với</span>
                        <hr class="mt-n2" />
                    </div>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="d-grid gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-secondary rounded-pill py-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                    <i class="bi bi-google me-2"></i> @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
