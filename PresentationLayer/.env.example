# ============================================================
#  .env.example — Copy file này thành .env rồi điền giá trị
#  KHÔNG commit file .env lên GitHub!
# ============================================================

# ── SQL Server Connection String ─────────────────────────────
# Thay <SERVER_NAME> bằng tên SQL Server instance của bạn
# Ví dụ: Server=localhost  hoặc  Server=MYPC\SQLEXPRESS
ConnectionStrings__DefaultConnection=Server=<SERVER_NAME>;Database=ChatbotRBLDb;uid=<SQL_USERNAME>;pwd=<SQL_PASSWORD>;TrustServerCertificate=True;MultipleActiveResultSets=true

# ── Google OAuth 2.0 ─────────────────────────────────────────
# Lấy từ: https://console.cloud.google.com/ → APIs & Services → Credentials
# Nếu không dùng Google Login, để trống (app vẫn chạy được)
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
Authentication__Google__ClientSecret=YOUR_GOOGLE_CLIENT_SECRET

# ── Groq API (LLM) ───────────────────────────────────────────
# Đăng ký tại: https://console.groq.com/
# Model gợi ý: llama-3.3-70b-versatile | mixtral-8x7b-32768
Groq__ApiKey=gsk_YOUR_GROQ_API_KEY_HERE
Groq__Model=llama-3.3-70b-versatile

# ── Python AI Embedding Service ──────────────────────────────
# URL của FastAPI service đang chạy ở bước 2
# Mặc định: http://127.0.0.1:8000/embed (chạy local)
Rag__EmbedApiUrl=http://127.0.0.1:8000/embed

# ── RAG Parameters ───────────────────────────────────────────
# TopK: Số lượng chunks liên quan tối đa trả về
# MinScore: Ngưỡng tối thiểu similarity score (0.0 - 1.0)
Rag__TopK=5
Rag__MinScore=0.6
