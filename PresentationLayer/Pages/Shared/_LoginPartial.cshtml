@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    var userPrefix = User.IsInRole("Admin") ? "🛡️" : User.IsInRole("Teacher") ? "👨‍🏫" : "👤";
    <li class="nav-item">
        <a class="nav-link text-dark fw-medium px-3" style="background-color: var(--background-light); border-radius: 20px;" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            @userPrefix @User.Identity?.Name
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")">
            <button type="submit" class="btn btn-outline-danger rounded-pill px-4" style="font-weight: 500;">Đăng xuất</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-primary rounded-pill px-4 text-white fw-medium shadow-sm" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
    </li>
}
</ul>
