@page
@model PresentationLayer.Pages.Pricing.VnpayReturnModel
@{
    ViewData["Title"] = "Kết quả thanh toán";
}

<div class="container py-5" style="max-width: 650px;">
    <div class="card border-0 rounded-4 shadow-lg p-5 text-center" style="background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(10px);">
        
        @if (Model.IsSuccess)
        {
            <div class="mb-4">
                <span class="display-1 text-success">🎉</span>
            </div>
            <h2 class="fw-bold text-success mb-3">Thanh toán thành công!</h2>
            <p class="text-secondary mb-4">
                Tài khoản của bạn đã được nâng cấp lên gói <strong>Học Tập (Standard)</strong> thành công. 
                Vui lòng tiếp tục trải nghiệm chatbot với giới hạn mới.
            </p>
        }
        else
        {
            <div class="mb-4">
                <span class="display-1 text-danger">⚠️</span>
            </div>
            <h2 class="fw-bold text-danger mb-3">Thanh toán thất bại!</h2>
            <p class="text-secondary mb-4">
                Yêu cầu thanh toán của bạn không thể hoàn tất hoặc chữ ký xác thực không hợp lệ. 
                Chi tiết lỗi: <span class="text-danger fw-medium">@Model.Message</span>
            </p>
        }

        <div class="bg-light rounded-3 p-4 mb-4 text-start small">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-secondary">Mã đơn hàng (TxnRef):</span>
                <span class="fw-bold">@Model.TxnRef</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-secondary">Mã giao dịch VNPAY:</span>
                <span class="fw-bold">@Model.TransactionNo</span>
            </div>
            <div class="d-flex justify-content-between">
                <span class="text-secondary">Số tiền:</span>
                <span class="fw-bold text-primary">@Model.Amount.ToString("N0") đ</span>
            </div>
        </div>

        <div class="d-flex justify-content-center gap-3">
            <a asp-page="/Index" class="btn btn-primary rounded-pill px-4 py-2 text-white fw-bold shadow-sm">
                Trò chuyện ngay
            </a>
            <a asp-page="/Pricing/Index" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                Bảng giá
            </a>
        </div>
    </div>
</div>
