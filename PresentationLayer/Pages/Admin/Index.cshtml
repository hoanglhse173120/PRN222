@page
@model PresentationLayer.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">👥 Quản lý Người dùng</h2>
            <p class="text-muted mb-0">Tạo, xoá tài khoản và phân công môn học cho giảng viên</p>
        </div>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-2"></i>Tạo tài khoản mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Email</th>
                        <th>Vai trò</th>
                        <th>Môn học được phân công</th>
                        <th>Gói dịch vụ</th>
                        <th>Hạn sử dụng</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="ps-4 align-middle fw-semibold">@user.Email</td>
                            <td class="align-middle">
                                @if (user.Role == "Teacher")
                                {
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">🎓 Giảng viên</span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">🎒 Sinh viên</span>
                                }
                            </td>
                            <td class="align-middle">
                                @if (user.Role == "Teacher" && user.AssignedSubjects.Any())
                                {
                                    @foreach (var s in user.AssignedSubjects)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary me-1 border">@s</span>
                                    }
                                }
                                else if (user.Role == "Teacher")
                                {
                                    <span class="text-muted fst-italic small">Chưa phân công</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="align-middle">
                                @if (user.Role == "Student")
                                {
                                    @if (user.IsPremium)
                                    {
                                        <span class="badge bg-warning text-dark border border-warning-subtle">
                                            👑 @user.SubscriptionPackage
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary small">Mặc định (Free)</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="align-middle small">
                                @if (user.Role == "Student" && user.IsPremium && user.ExpiryDate.HasValue)
                                {
                                    <span class="fw-medium">@user.ExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="align-middle text-end pe-4">
                                @if (user.Role == "Teacher")
                                {
                                    <a asp-page="AssignSubjects" asp-route-userId="@user.UserId"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-book me-1"></i>Phân công môn
                                    </a>
                                }
                                <form asp-page-handler="DeleteUser" method="post" class="d-inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xoá tài khoản @user.Email?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-people fs-2 d-block mb-2 opacity-25"></i>
                                Chưa có tài khoản nào. Hãy tạo mới!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (function () {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .build();

            connection.on("NewUserRegistered", function (data) {
                showToast("👤", "Tài khoản mới!", `Tài khoản ${data.Email} vừa được tạo với vai trò ${data.Role}.`, "#3B82F6", "#2563EB");
                setTimeout(() => location.reload(), 1500);
            });

            connection.on("UserListUpdated", function () {
                showToast("🔄", "Cập nhật danh sách", "Danh sách người dùng đã có sự thay đổi.", "#6B7280", "#4B5563");
                setTimeout(() => location.reload(), 1500);
            });

            connection.start().catch(err => console.warn("SignalR Admin Index: không thể kết nối:", err));

            function showToast(icon, title, subtitle, colorFrom, colorTo) {
                const toast = document.createElement("div");
                toast.style.cssText = `
                    position: fixed; bottom: 24px; right: 24px; z-index: 9999;
                    background: linear-gradient(135deg, ${colorFrom}, ${colorTo});
                    color: white; padding: 1rem 1.4rem; border-radius: 16px;
                    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
                    font-family: Inter, sans-serif; font-size: 0.9rem;
                    display: flex; align-items: center; gap: 0.75rem;
                    animation: slideInRight 0.4s ease; max-width: 380px;
                `;
                toast.innerHTML = `
                    <span style="font-size:1.4rem">${icon}</span>
                    <div>
                        <div style="font-weight:600">${title}</div>
                        <div style="opacity:0.85;font-size:0.8rem;margin-top:2px">${subtitle}</div>
                    </div>
                `;
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 2000);
            }
        })();
    </script>
    <style>
    @@keyframes slideInRight {
        from { opacity: 0; transform: translateX(40px); }
        to   { opacity: 1; transform: translateX(0); }
    }
    </style>
}
