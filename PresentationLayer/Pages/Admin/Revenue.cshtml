@page
@model PresentationLayer.Pages.Admin.RevenueModel
@{
    ViewData["Title"] = "Thống kê doanh thu";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold text-dark mb-1"><i class="bi bi-cash-coin text-success"></i> Thống kê doanh thu</h1>
            <p class="text-secondary mb-0">Tổng quan về tình hình tài chính và các gói đăng ký của hệ thống.</p>
        </div>
        <div>
            <a asp-page-handler="ExportCsv" class="btn btn-outline-success px-4 py-2 rounded-pill shadow-sm me-2">
                <i class="bi bi-file-earmark-spreadsheet me-2"></i>Xuất Excel (CSV)
            </a>
            <a asp-page="/Admin/Transactions" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-list-check me-2"></i>Xem chi tiết giao dịch
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card text-white bg-warning h-100 shadow-sm border-0 rounded-4" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title fw-semibold mb-0">Doanh Thu Tổng</h5>
                        <div class="bg-white text-warning rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 48px; height: 48px;">
                            <i class="bi bi-currency-dollar fs-4"></i>
                        </div>
                    </div>
                    <h2 class="display-5 fw-bold mb-1">@Model.TotalRevenue.ToString("N0") VNĐ</h2>
                    <p class="card-text text-white-50 fs-6">Tổng doanh thu từ các giao dịch thành công</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card text-white bg-danger h-100 shadow-sm border-0 rounded-4" style="background: linear-gradient(135deg, #ef4444, #b91c1c);">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title fw-semibold mb-0">Gói Đăng Ký</h5>
                        <div class="bg-white text-danger rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 48px; height: 48px;">
                            <i class="bi bi-lightning-charge fs-4"></i>
                        </div>
                    </div>
                    <h2 class="display-5 fw-bold mb-1">@Model.ActiveSubscriptions</h2>
                    <p class="card-text text-white-50 fs-6">Số gói (subscription) đang kích hoạt hiện tại</p>
                </div>
            </div>
        </div>
    </div>
</div>
