@page
@model PresentationLayer.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "Bắt đầu Chat";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 mb-4">RAG Chatbot</h1>
            <p class="lead text-muted mb-5">Chọn môn học để bắt đầu ôn tập hoặc đặt câu hỏi</p>

            <div class="row g-4">
                <!-- Chat Tự do (Global) -->
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 hover-lift">
                        <div class="card-body p-4">
                            <div class="icon-circle bg-primary text-white mb-3 mx-auto">
                                <i class="bi bi-globe fs-3"></i>
                            </div>
                            <h5 class="card-title fw-bold">Chat Tự do</h5>
                            <p class="card-text text-muted small">Chat chung không giới hạn môn học.</p>
                            <form method="post" asp-page-handler="StartChat">
                                <input type="hidden" name="subjectId" value="" />
                                <button type="submit" class="btn btn-outline-primary w-100 stretched-link mt-2">Bắt đầu</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Các môn học -->
                @foreach (var subject in Model.Subjects)
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="card h-100 shadow-sm border-0 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-circle bg-success text-white mb-3 mx-auto">
                                    <i class="bi bi-book fs-3"></i>
                                </div>
                                <h5 class="card-title fw-bold text-truncate" title="@subject.SubjectName">@subject.SubjectName</h5>
                                <p class="card-text text-muted small text-truncate" title="@subject.Description">@(string.IsNullOrEmpty(subject.Description) ? "Tài liệu môn " + subject.SubjectName : subject.Description)</p>
                                <form method="post" asp-page-handler="StartChat">
                                    <input type="hidden" name="subjectId" value="@subject.SubjectID" />
                                    <button type="submit" class="btn btn-outline-success w-100 stretched-link mt-2">Bắt đầu</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.RecentSessions.Any())
            {
                <div class="mt-5 text-start">
                    <h4 class="mb-3">Lịch sử Chat gần đây</h4>
                    <div class="list-group shadow-sm">
                        @foreach (var session in Model.RecentSessions)
                        {
                            <a asp-page="/Chat/Session" asp-route-id="@session.SessionID" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                                <div>
                                    <h6 class="mb-1 fw-bold">@(string.IsNullOrEmpty(session.SubjectName) ? "Chat Tự do" : session.SubjectName)</h6>
                                    <small class="text-muted">@session.CreatedAt.ToString("g")</small>
                                </div>
                                <i class="bi bi-chevron-right text-muted"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
