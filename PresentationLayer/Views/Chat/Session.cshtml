@model PresentationLayer.ViewModels.ChatSessionViewModel
@{
    ViewData["Title"] = Model.Session.SessionName;
}

<style>
    .chat-container {
        height: 60vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        padding: 1rem;
        background-color: #f8f9fa;
        border-radius: 8px;
        border: 1px solid #dee2e6;
    }
    .msg-bubble {
        max-width: 80%;
        padding: 10px 15px;
        border-radius: 15px;
        margin-bottom: 10px;
        word-wrap: break-word;
    }
    .msg-user {
        background-color: #0d6efd;
        color: white;
        align-self: flex-end;
        border-bottom-right-radius: 0;
    }
    .msg-ai {
        background-color: #e9ecef;
        color: black;
        align-self: flex-start;
        border-bottom-left-radius: 0;
    }
    .msg-time {
        font-size: 0.75rem;
        opacity: 0.7;
        margin-top: 5px;
        display: block;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><a asp-action="Index" class="text-decoration-none text-dark"><i class="bi bi-arrow-left"></i></a> @Model.Session.SessionName</h2>
    <span class="text-muted small">Tạo lúc: @Model.Session.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <!-- Chat History -->
        <div class="chat-container mb-3" id="chatBox">
            @if (!Model.Session.ChatMessages.Any())
            {
                <div class="text-center text-muted my-auto">
                    <p>🤖 Xin chào! Hãy đặt câu hỏi về các tài liệu đã được index.</p>
                </div>
            }
            else
            {
            @foreach (var msg in Model.Session.ChatMessages.OrderBy(m => m.Timestamp))
                {
                    <div class="msg-bubble @(msg.Role == "user" ? "msg-user" : "msg-ai")">
                        <div>
                            @if (msg.Role == "assistant")
                            {
                                <strong>🤖 AI: </strong>
                            }
                            else
                            {
                                <strong>👤 Bạn: </strong>
                            }
                            @{
                                // Render **bold** và newline
                                var rendered = System.Text.RegularExpressions.Regex
                                    .Replace(msg.MessageText, @"\*\*(.*?)\*\*", "<strong>$1</strong>")
                                    .Replace("\n", "<br/>");
                            }
                            @Html.Raw(rendered)
                        </div>
                        <span class="msg-time">@msg.Timestamp.ToString("HH:mm")</span>
                    </div>
                }
            }
        </div>

        <!-- Chat Input -->
        <div class="card shadow-sm border-0 bg-light">
            <div class="card-body p-2">
                <form asp-action="SendMessage" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.Session.SessionID" />
                    <input type="text" name="newMessage" class="form-control border-0 bg-white shadow-none" 
                           placeholder="Nhập câu hỏi của bạn..." required autocomplete="off" autofocus />
                    <button type="submit" class="btn btn-primary rounded-circle" style="width: 45px; height: 45px;">
                        <span style="font-size: 1.2rem;">➤</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động cuộn xuống cuối khi load trang
        var chatBox = document.getElementById("chatBox");
        chatBox.scrollTop = chatBox.scrollHeight;
    </script>
}
