@model IEnumerable<ServiceLayer.DTOs.ChatSessionDto>
@{
    ViewData["Title"] = "Trò chuyện AI";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom fade-in-up">
    <h2 class="fw-bold mb-0" style="color: var(--primary);">💬 Phiên trò chuyện</h2>
    <form asp-action="Create" method="post" class="d-flex gap-2 align-items-center">
        @Html.AntiForgeryToken()
        <input type="text" name="sessionName" class="form-control rounded-pill px-4" placeholder="Tên phiên mới (tùy chọn)" style="max-width: 250px; background-color: var(--glass-bg);" />
        <button type="submit" class="btn btn-primary rounded-pill text-nowrap px-4 py-2 shadow-sm"><i class="bi bi-plus-lg me-1"></i> Tạo phiên mới</button>
    </form>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm" role="alert" style="background-color: #d1fae5; border: none; color: #065f46;">
        @TempData["Success"]
        <button type="button" class="btn-close mt-1 me-2" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 fade-in-up">
        <div class="mb-4" style="font-size: 4rem; color: var(--primary); opacity: 0.5;">
            <i class="bi bi-chat-square-dots"></i>
        </div>
        <h4 class="fw-bold text-dark">Chưa có phiên trò chuyện nào</h4>
        <p class="text-muted mb-4">Hãy tạo một phiên mới để bắt đầu khám phá tri thức cùng AI.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 fade-in-up">
        @foreach (var session in Model.OrderByDescending(s => s.CreatedAt))
        {
            <div class="col">
                <div class="card h-100 glass-card transition-all" style="transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold text-dark mb-2 text-truncate" title="@session.SessionName">@session.SessionName</h5>
                        <p class="card-text text-muted small mb-4">
                            <i class="bi bi-clock me-1"></i> Tạo lúc: @session.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </p>
                        <div class="mt-auto d-flex justify-content-between align-items-center pt-3 border-top" style="border-color: rgba(0,0,0,0.05) !important;">
                            <a asp-action="Session" asp-route-id="@session.SessionID" class="btn btn-primary rounded-pill btn-sm px-3 shadow-sm">Vào Chat <i class="bi bi-arrow-right ms-1"></i></a>
                            <form asp-action="Delete" asp-route-id="@session.SessionID" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa phiên trò chuyện này không?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="bi bi-trash3"></i> Xóa</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <style>
        .glass-card:hover { transform: translateY(-5px); box-shadow: 0 10px 40px rgba(0,0,0,0.1); }
    </style>
}
