@model IEnumerable<ServiceLayer.DTOs.ChatSessionDto>
@{
    ViewData["Title"] = "Trò chuyện AI";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>💬 Phiên trò chuyện</h2>
    <form asp-action="Create" method="post" class="d-flex gap-2">
        @Html.AntiForgeryToken()
        <input type="text" name="sessionName" class="form-control" placeholder="Tên phiên mới (tùy chọn)" />
        <button type="submit" class="btn btn-primary text-nowrap">+ Tạo phiên mới</button>
    </form>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có phiên trò chuyện nào. Hãy tạo phiên mới để bắt đầu!</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var session in Model.OrderByDescending(s => s.CreatedAt))
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary">@session.SessionName</h5>
                        <p class="card-text text-muted small mb-3">
                            <i class="bi bi-clock"></i> Tạo lúc: @session.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </p>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <a asp-action="Session" asp-route-id="@session.SessionID" class="btn btn-outline-primary btn-sm">Vào Chat</a>
                            <form asp-action="Delete" asp-route-id="@session.SessionID" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa phiên trò chuyện này không?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
