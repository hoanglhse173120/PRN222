@model PresentationLayer.ViewModels.DocumentUploadViewModel
@{
    ViewData["Title"] = "Upload Tài liệu";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">⬆ Upload Tài liệu</h4>
            </div>
            <div class="card-body">

                @if (!Model.Subjects.Any())
                {
                    <div class="alert alert-warning">
                        Chưa có môn học nào. Hãy <a asp-controller="Subject" asp-action="Create">tạo môn học</a> trước.
                    </div>
                }
                else
                {
                    <form asp-action="Upload" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="SubjectId" class="form-label fw-bold">Môn học <span class="text-danger">*</span></label>
                            <select asp-for="SubjectId" class="form-select">
                                <option value="">-- Chọn môn học --</option>
                                @foreach (var s in Model.Subjects)
                                {
                                    <option value="@s.SubjectID">@s.SubjectName</option>
                                }
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="File" class="form-label fw-bold">Chọn file <span class="text-danger">*</span></label>
                            <input asp-for="File" type="file" class="form-control"
                                   accept=".pdf,.docx,.doc,.pptx,.ppt" />
                            <div class="form-text">Chấp nhận: PDF, DOCX, PPTX (tối đa 50MB)</div>
                            <span asp-validation-for="File" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">⬆ Upload</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h6 class="fw-bold">ℹ️ Quy trình sau khi upload:</h6>
                <ol class="mb-0 small text-muted">
                    <li>File được lưu vào server</li>
                    <li>Tài liệu hiển thị trong danh sách với trạng thái <span class="badge bg-warning text-dark">Chờ Index</span></li>
                    <li>Nhấn nút <strong>✅ Index</strong> để bắt đầu chunk & embed tài liệu</li>
                    <li>Sau khi index, chatbot có thể sử dụng tài liệu này để trả lời</li>
                </ol>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
