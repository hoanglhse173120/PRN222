@model ServiceLayer.DTOs.DocumentDetailsDto
@{
    ViewData["Title"] = "Chi tiết tài liệu: " + Model.FileName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>
        <a asp-action="Index" class="text-decoration-none text-dark">
            <i class="bi bi-arrow-left"></i>
        </a>
        📄 Chi tiết: <span class="text-primary">@Model.FileName</span>
    </h2>
    <span class="badge @(Model.IsIndexed ? "bg-success" : "bg-warning text-dark") fs-6">
        @(Model.IsIndexed ? "✅ Đã Index" : "⏳ Chưa Index")
    </span>
</div>

@* Thông tin tổng quan *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">📦</div>
                <div class="fw-bold fs-4 text-primary">@Model.TotalChunks</div>
                <div class="text-muted small">Tổng chunks</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">🔢</div>
                <div class="fw-bold fs-4 text-success">@Model.ChunksWithEmbedding</div>
                <div class="text-muted small">Có embedding vector</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">📚</div>
                <div class="fw-bold fs-4">@(Model.Subject?.SubjectName ?? "—")</div>
                <div class="text-muted small">Môn học</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">💾</div>
                <div class="fw-bold fs-4">@(Model.FileSizeKB.HasValue ? $"{Model.FileSizeKB:N0} KB" : "—")</div>
                <div class="text-muted small">Kích thước</div>
            </div>
        </div>
    </div>
</div>

@* Danh sách chunks *@
<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <span>📋 Danh sách Chunks đã tách</span>
        <small>Upload: @Model.UploadedAt.ToString("dd/MM/yyyy HH:mm")</small>
    </div>
    <div class="card-body p-0">
        @if (!Model.Chunks.Any())
        {
            <div class="alert alert-warning m-3">
                Tài liệu này chưa được Index. Quay lại danh sách và nhấn nút <strong>✅ Index</strong>.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th style="width: 60px">#</th>
                            <th>Nội dung chunk</th>
                            <th style="width: 80px" class="text-center">Vector</th>
                            <th style="width: 130px">Tạo lúc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var chunk in Model.Chunks)
                        {
                            <tr>
                                <td class="text-muted fw-bold">@chunk.ChunkIndex</td>
                                <td>
                                    <div class="chunk-content">@chunk.ChunkContent</div>
                                </td>
                                <td class="text-center">
                                    @if (chunk.HasEmbedding)
                                    {
                                        <span class="badge bg-success" title="Có embedding vector">✓</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" title="Chưa có embedding">—</span>
                                    }
                                </td>
                                <td class="text-muted small">@chunk.CreatedAt.ToString("HH:mm dd/MM")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .chunk-content {
        max-height: 80px;
        overflow: hidden;
        font-size: 0.85rem;
        color: #444;
        white-space: pre-wrap;
        word-break: break-word;
    }
</style>
