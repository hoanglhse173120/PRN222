@model DataAccessLayer.Models.Subject
@{
    ViewData["Title"] = "Sửa Môn học";
}

<h2>Sửa Môn học</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="SubjectID" type="hidden" />
            <div class="mb-3">
                <label asp-for="SubjectName" class="form-label fw-bold">Tên môn học <span class="text-danger">*</span></label>
                <input asp-for="SubjectName" class="form-control" />
                <span asp-validation-for="SubjectName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
