@model ServiceLayer.DTOs.SubjectDto
@{
    ViewData["Title"] = "Thêm Môn học";
}

<h2>Thêm Môn học mới</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="SubjectName" class="form-label fw-bold">Tên môn học <span class="text-danger">*</span></label>
                <input asp-for="SubjectName" class="form-control" placeholder="VD: Trí tuệ Nhân tạo" />
                <span asp-validation-for="SubjectName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn về môn học..."></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Tạo môn học</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
