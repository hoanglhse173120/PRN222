@model PresentationLayer.ViewModels.Admin.CreateUserViewModel
@{
    ViewData["Title"] = "Tạo tài khoản mới";
}

<div class="container py-5" style="max-width:520px">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-person-plus me-2"></i>Tạo tài khoản mới</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="vd: nguyenvana@gmail.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" placeholder="Ít nhất 6 ký tự" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold">Xác nhận mật khẩu</label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label fw-semibold">Vai trò</label>
                    <select asp-for="Role" class="form-select">
                        <option value="">— Chọn vai trò —</option>
                        <option value="Teacher">🎓 Giảng viên (Teacher)</option>
                        <option value="Student">🎒 Sinh viên (Student)</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="bi bi-check-lg me-1"></i>Tạo tài khoản
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
