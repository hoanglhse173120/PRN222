@model List<PresentationLayer.ViewModels.Admin.UserListItemViewModel>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">👥 Quản lý Người dùng</h2>
            <p class="text-muted mb-0">Tạo, xoá tài khoản và phân công môn học cho giảng viên</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-2"></i>Tạo tài khoản mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Email</th>
                        <th>Vai trò</th>
                        <th>Môn học được phân công</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 align-middle fw-semibold">@user.Email</td>
                            <td class="align-middle">
                                @if (user.Role == "Teacher")
                                {
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">🎓 Giảng viên</span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">🎒 Sinh viên</span>
                                }
                            </td>
                            <td class="align-middle">
                                @if (user.Role == "Teacher" && user.AssignedSubjects.Any())
                                {
                                    @foreach (var s in user.AssignedSubjects)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary me-1 border">@s</span>
                                    }
                                }
                                else if (user.Role == "Teacher")
                                {
                                    <span class="text-muted fst-italic small">Chưa phân công</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="align-middle text-end pe-4">
                                @if (user.Role == "Teacher")
                                {
                                    <a asp-action="AssignSubjects" asp-route-userId="@user.UserId"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-book me-1"></i>Phân công môn
                                    </a>
                                }
                                <form asp-action="DeleteUser" method="post" class="d-inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xoá tài khoản @user.Email?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-people fs-2 d-block mb-2 opacity-25"></i>
                                Chưa có tài khoản nào. Hãy tạo mới!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
